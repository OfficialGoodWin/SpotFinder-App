rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read public spots
    match /spots/{spotId} {
      allow read: if true;
      // Allow anyone to create spots (including anonymous)
      allow create: if true;
      // Allow any authenticated user to update spots (needed for rating updates)
      allow update: if request.auth != null;
      // Allow spot owners OR superadmin to delete spots
      allow delete: if request.auth != null && (resource.data.created_by == request.auth.token.email || request.auth.token.email == 'superadmin@spotfinder.cz');
    }

    
    // Allow anyone to read ratings, allow anyone to create ratings (including anonymous)
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if true;
    }
  }
}
